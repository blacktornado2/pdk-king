# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env

# PostgreSQL connection string (Prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pdfking?schema=public"

# Redis (BullMQ queue)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# NestJS server port
PORT="3001"

# Where uploaded/processed files are stored (relative to server/)
UPLOAD_DIR="./uploads"

# How long generated output files live before cleanup, in hours
FILE_EXPIRY_HOURS="1"
