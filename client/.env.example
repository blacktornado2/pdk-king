# Copy this file to `.env` only if you need to override defaults.
#   cp .env.example .env
#
# All client env vars MUST be prefixed with VITE_ to be exposed to the app.

# Base URL of the backend API.
# Leave UNSET in development — the Vite dev server proxies '/api' to the
# backend (see vite.config.ts), so the app uses the relative '/api/v1' default.
# In production (no Vite proxy), set this to the deployed API base, e.g.:
#   VITE_API_URL=https://api.your-domain.com/api/v1
# VITE_API_URL=
